<UserControl x:Class="TourPlanner_SAWA_KIM.Views.TourTabControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TourPlanner_SAWA_KIM.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
	<TabControl>
		<!-- Home Tab -->
		<TabItem Header="General">
			<!-- Content for Home tab -->
			<StackPanel>
				<TextBlock Text="Welcome to the Home Page" FontSize="16" Padding="10" />
				<!-- Additional content here -->
			</StackPanel>
		</TabItem>

		<!-- Account Tab -->
		<TabItem Header="Route">
			<!-- Content for Account tab -->
			<StackPanel>
				<TextBlock Text="Account Settings" FontSize="16" Padding="10" />
				<!-- Additional content here -->
			</StackPanel>
		</TabItem>

		<!-- Another Tab -->
		<TabItem Header="Misc">
			<!-- Content for Settings tab -->
			<StackPanel>
				<TextBlock Text="Configure your settings" FontSize="16" Padding="10" />
				<!-- Additional content here -->
			</StackPanel>
		</TabItem>
	</TabControl>
</UserControl>
